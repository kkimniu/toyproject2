<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.roommate.domain.chat.repository.ChatMessageRepository">
    <resultMap id="chatMessageMap" type="com.roommate.domain.chat.entity.ChatMessageEntity">
        <id property="messageId" column="message_id"/>
        <result property="chatRoomId" column="chat_room_id"/>
        <result property="senderId" column="sender_id"/>
        <result property="senderName" column="sender_name"/>
        <result property="message" column="message"/>
        <result property="sentAt" column="sent_at"/>
    </resultMap>

    <insert id="save" parameterType="com.roommate.domain.chat.entity.ChatMessageEntity" useGeneratedKeys="true" keyProperty="messageId">
        INSERT INTO chat_messages (
            chat_room_id,
            sender_id,
            message
        ) VALUES (
            #{chatRoomId},
            #{senderId},
            #{message}
        )
    </insert>

    <select id="findByChatRoomId" resultMap="chatMessageMap">
        SELECT
            cm.message_id,
            cm.chat_room_id,
            cm.sender_id,
            m.name AS sender_name,
            cm.message,
            cm.sent_at
        FROM chat_messages cm
        JOIN members m ON m.member_id = cm.sender_id
        WHERE cm.chat_room_id = #{chatRoomId}
          AND cm.is_deleted = 0
        ORDER BY cm.sent_at ASC, cm.message_id ASC
    </select>
</mapper>
