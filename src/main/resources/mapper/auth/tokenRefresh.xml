<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.roommate.domain.auth.repository.AuthRepository">
    <insert id="save" useGeneratedKeys="true" keyProperty="tokenId">
        INSERT INTO token_refresh (
        member_id,
        refresh_token_hash,
        expires_at
        )
        VALUES (
        #{memberId},
        #{refreshTokenHash},
        #{expiresAt}
        )
    </insert>
</mapper>