<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
    왜: RoomImageRepository 인터페이스와 1:1 매핑되는 Mapper.
    - 방 이미지 단건 INSERT
    - 방별 전체 삭제
    - 방별 이미지 URL 목록 조회
-->
<mapper namespace="com.roommate.domain.room.repository.RoomImageRepository">
    <!--
        방별 이미지 전체 삭제
        - 방 수정 시 기존 이미지를 전부 제거하고 새로 넣기 위해 사용
    -->
    <delete id="deleteByRoomId">
        DELETE
        FROM room_image
        WHERE room_id = #{roomId}
    </delete>

    <!--
        이미지 한 장 INSERT
        - RoomImageRepository.replaceRoomImages() 에서 반복 호출
        - sort_order: 노출 순서 (0부터 시작 가정)
    -->
    <insert id="insertRoomImage">
        INSERT INTO room_image (
        room_id,
        image_url,
        sort_order
        ) VALUES (
        #{roomId},
        #{imageUrl},
        #{sortOrder}
        )
    </insert>

    <!--
        방의 이미지 URL 목록 조회
        - 상세 화면에서 이미지를 보여줄 때 사용
        - URL만 필요하므로 resultType="string" 으로 심플하게 반환
    -->
    <select id="findImageUrlsByRoomId" resultType="string">
        SELECT image_url
        FROM room_image
        WHERE room_id = #{roomId}
        ORDER BY sort_order ASC, image_id ASC
    </select>

    <select id="findAllImageUrls" resultType="string">
        SELECT image_url
        FROM room_image
        WHERE deleted = 0
    </select>

</mapper>
