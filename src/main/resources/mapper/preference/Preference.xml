<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.roommate.domain.member.repository.PreferenceRepository">
    <resultMap id="preferenceMap" type="com.roommate.domain.member.entity.PreferenceEntity">
        <id property="preferenceId" column="preference_id"/>
        <result property="preferenceName" column="preference_name"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findAll" resultMap="preferenceMap">
        SELECT *
        FROM preferences
        ORDER BY preference_name
    </select>
    <select id="findById" resultMap="preferenceMap">
        SELECT *
        FROM preferences
        WHERE preference_id = #{preferenceId}
    </select>
    <select id="findByName" resultMap="preferenceMap">
        SELECT *
        FROM preferences
        WHERE preference_name = #{name}
    </select>
    <select id="findByMemberId" parameterType="long" resultType="com.roommate.domain.member.entity.PreferenceEntity">
        SELECT p.preference_id,
        p.preference_name,
        p.created_at
        FROM preferences p
        JOIN member_preferences mp ON p.preference_id = mp.preference_id
        WHERE mp.member_id = #{memberId}
    </select>
    <insert id="insert">
        INSERT INTO preferences (preference_name)
        VALUES (#{name})
    </insert>
    <update id="update">
        UPDATE preferences
        SET preference_name = #{name}
        WHERE preference_id = #{preferenceId}
    </update>
    <delete id="delete">
        DELETE FROM preferences
        WHERE preference_id = #{preferenceId}
    </delete>

</mapper>
