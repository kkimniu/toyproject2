<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.roommate.domain.member.repository.WorkTypeRepository">
    <resultMap id="workTypeMap" type="com.roommate.domain.member.entity.WorkTypeEntity">
        <id property="workTypeId" column="work_type_id"/>
        <result property="workTypeName" column="work_type_name"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>
    <select id="findAll" resultMap="workTypeMap">
        SELECT *
        FROM work_types
    </select>
    <select id="findById" resultMap="workTypeMap">
        SELECT *
        FROM work_types
        WHERE work_type_id = #{workTypeId}
    </select>
</mapper>
